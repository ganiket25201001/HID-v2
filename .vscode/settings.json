    "chat.tools.terminal.autoApprove": {
        "git remote": true,
        "git push": true,
        "ForEach-Object": true,
        "Get-Command": true
    },
    "python-envs.defaultEnvManager": "ms-python.python:system",
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        "./sandbox",
        "-p",
        "*test.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true
}