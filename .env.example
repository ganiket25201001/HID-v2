# =============================================================================
# HID Shield – Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file to version control.
# =============================================================================

# Master encryption key (base64-encoded, 32 bytes).
# Generate with: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
HID_SHIELD_ENCRYPTION_KEY=""

# Override the database path (absolute or relative to app data dir).
# HID_SHIELD_DB_PATH="hid_shield.db"

# Set to "true" to enable simulation mode (no real USB access required).
HID_SHIELD_SIMULATION_MODE="true"

# Enable verbose SQL echo for debugging.
# HID_SHIELD_DB_ECHO="false"

# Admin PIN hash (bcrypt / argon2 — set during first-run wizard).
# HID_SHIELD_ADMIN_PIN_HASH=""

# Logging level override (DEBUG | INFO | WARNING | ERROR | CRITICAL).
HID_SHIELD_LOG_LEVEL="INFO"
